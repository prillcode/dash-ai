# SQLite (local file, auto-created on first run)
# Default: ~/.dash-ai/dashboard.db
# Override with an absolute or ~/relative path:
# SQLITE_DB_PATH=~/.dash-ai/dashboard.db

# OpenCode working directory
OPENCODE_WORKING_DIR=/home/user/agent-workspaces

# Local storage for diffs and session logs
DIFF_STORAGE_DIR=~/.dash-ai/diffs
LOG_STORAGE_DIR=~/.dash-ai/sessions

# Skills base directory (for file-based skills path validation)
SKILLS_BASE_DIR=~/.dash-ai/skills

# Auth — all API requests require: Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me

# Queue worker
MAX_CONCURRENT_SESSIONS=3

# Server
PORT=3210
NODE_ENV=development

# Client (Vite exposes VITE_ prefixed vars to browser)
VITE_API_TOKEN=change-me # Must match API_TOKEN for client to authenticate

# Pi agent now dynamically loads providers and models from ~/.pi/agent/auth.json (so API keys are no longer needed in .env).
