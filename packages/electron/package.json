{
  "name": "dash-ai-electron",
  "version": "1.0.0",
  "private": true,
  "description": "Dash AI desktop app with embedded local server",
  "homepage": "https://github.com/prillcode/dash-ai",
  "author": {
    "name": "Aaron Prill",
    "email": "prillcode@gmail.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm run build:main && pnpm run build:preload && electron . --enable-logging --no-sandbox",
    "build": "pnpm run build:server && pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "build:server": "pnpm --filter @dash-ai/server build",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "pnpm --filter @dash-ai/client build",
    "preview": "electron-vite preview",
    "dist": "pnpm run build && electron-builder",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:win": "pnpm run build && electron-builder --win"
  },
  "dependencies": {
    "@dash-ai/server": "workspace:*",
    "dotenv": "^17.3.1",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.2.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.dashai.app",
    "productName": "Dash-AI",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmRebuild": false,
    "icon": "build/icons/icon.png",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server/dist"
      },
      {
        "from": "../client/dist",
        "to": "client/dist"
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "build/icons",
      "executableName": "dash-ai",
      "maintainer": "Aaron Prill <prillcode@gmail.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
