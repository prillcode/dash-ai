# Dash AI Server Configuration

# API token for authenticating requests (Bearer token)
API_TOKEN=your-api-token-here

# Server port
PORT=3000

# Maximum concurrent Pi SDK agent sessions (default: 2)
MAX_CONCURRENT_SESSIONS=2

# Pi SDK agent directory (optional, defaults to ~/.pi/agent)
# PI_AGENT_DIR=~/.pi/agent

# Provider API keys — Pi SDK reads these automatically
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GOOGLE_API_KEY=...
